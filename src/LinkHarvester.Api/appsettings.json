{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Persistence": {
    "DbPath": "data/linkharvester.db"
  },
  "Auth": {
    "Username": "admin",
    "Password": "change-me",
    "CookieDurationDays": 30
  },
  "Harvester": {
    "ScanIntervalMinutes": 30,
    "ScanOnStartup": false,
    "MaxArticlesPerScan": 60,
    "MaxConcurrentResolutions": 1,
    "HosterPriority": [ "1fichier", "Rapidgator" ],
    "ResolveAutomaticallyAfterIngest": false
  },
  "Resolver": {
    "PersistentProfileDirectory": "data/playwright-profile",
    "Headed": false,
    "OverallTimeoutSeconds": 60,
    "MaxAttemptsPerLink": 3
  },
  "CapSolver": {
    "ApiKey": "",
    "ApiBaseUrl": "https://api.capsolver.com",
    "MonthlyBudgetUsd": 20,
    "AssumedCostPerSolveUsd": 0.0008,
    "PollIntervalMs": 2000,
    "MaxPollAttempts": 60,
    "Enabled": false
  },
  "Synology": {
    "BaseUrl": "",
    "Username": "",
    "Password": "",
    "OtpCode": null,
    "DefaultMovieDestination": "video/movies",
    "DefaultSeriesDestination": "video/series",
    "RequestTimeoutSeconds": 30
  }
}
