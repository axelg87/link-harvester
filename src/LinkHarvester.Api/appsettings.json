{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Persistence": {
    "DbPath": "data/linkharvester.db"
  },
  "Auth": {
    "Username": "admin",
    "Password": "change-me"
  },
  "Synology": {
    "DefaultMovieDestination": "video/movies",
    "DefaultSeriesDestination": "video/series"
  },
  "Harvester": {
    "ScanIntervalMinutes": 30,
    "ScanOnStartup": true,
    "MaxArticlesPerScan": 60,
    "HosterPriority": [ "1fichier", "Rapidgator" ]
  },
  "Resolver": {
    "OverallTimeoutSeconds": 30,
    "MaxAttemptsPerLink": 2
  },
  "CapSolver": {
    "ApiKey": "",
    "Enabled": false,
    "MonthlyBudgetUsd": 20
  }
}
