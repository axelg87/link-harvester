@inherits LayoutComponentBase
@inject HarvesterApi Api
@inject NavigationManager Nav

<div class="lh-shell">
    <header class="lh-header">
        <div class="lh-brand">Link Harvester</div>
        <div class="lh-spacer"></div>
        @if (_authChecked && _authed)
        {
            <a class="lh-iconbtn" href="/" title="Inbox"><span class="lh-icon">✉</span></a>
            <a class="lh-iconbtn" href="/catalog" title="Catalog"><span class="lh-icon">🗂</span></a>
            <a class="lh-iconbtn" href="/history" title="History"><span class="lh-icon">↺</span></a>
            <a class="lh-iconbtn" href="/backfill" title="Backfill &amp; Health"><span class="lh-icon">⛏</span></a>
            <a class="lh-iconbtn" href="/settings" title="Settings">
                <span class="lh-icon">⚙</span>
            </a>
            <button class="lh-iconbtn" @onclick="Logout" title="Logout">
                <span class="lh-icon">⎋</span>
            </button>
        }
    </header>
    <main class="lh-main">
        @Body
    </main>
</div>

@code {
    private bool _authChecked;
    private bool _authed;

    protected override async Task OnInitializedAsync()
    {
        _authed = await Api.IsAuthenticatedAsync();
        _authChecked = true;
        if (!_authed && !Nav.Uri.Contains("/login", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/login");
        }
    }

    private async Task Logout()
    {
        await Api.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
