@inject HarvesterApi Api

<div class="lh-inbox">
    <div class="lh-toolbar">
        <span class="lh-count">@_cards.Count item@(_cards.Count == 1 ? "" : "s")</span>
        <button class="lh-secondary" @onclick="Refresh">Refresh</button>
        <button class="lh-primary" @onclick="ScanNow">Scan now</button>
    </div>

    @if (_loading)
    {
        <p class="lh-muted">Loading…</p>
    }
    else if (_cards.Count == 0)
    {
        <div class="lh-empty">
            <p>No new items.</p>
            <p class="lh-muted">Hit "Scan now" to fetch the latest from the sources.</p>
        </div>
    }
    else
    {
        @foreach (var card in _cards)
        {
            <article class="lh-card @(card.BetterAvailable ? "lh-card-upgrade" : "")">
                <header class="lh-card-head">
                    <div class="lh-card-title">
                        @card.DisplayTitle
                        @if (card.Year is int y) { <span class="lh-year">(@y)</span> }
                    </div>
                    <span class="lh-tag lh-tag-kind">@FormatKind(card)</span>
                </header>

                @if (card.BetterAvailable)
                {
                    <div class="lh-banner">⭐ Better quality available — upgrade?</div>
                }

                <div class="lh-card-quality">
                    <span class="lh-tag lh-tag-quality">@card.Chosen.QualityLabel</span>
                    @if (!string.IsNullOrEmpty(card.Chosen.Language))
                    {
                        <span class="lh-tag">@card.Chosen.Language</span>
                    }
                    @if (card.Chosen.SizeBytes is long sz)
                    {
                        <span class="lh-meta">@FormatSize(sz)</span>
                    }
                    @if (card.Chosen.EpisodeCount is int ec)
                    {
                        <span class="lh-meta">@ec ep.</span>
                    }
                </div>

                <div class="lh-hosters">
                    @foreach (var h in card.Chosen.Hosters)
                    {
                        <span class="lh-pill">@h.Hoster<span class="lh-pill-count">@h.LinkCount</span></span>
                    }
                </div>

                @if (card.OtherVariants.Count > 0)
                {
                    <details class="lh-variants">
                        <summary>@card.OtherVariants.Count other variant@(card.OtherVariants.Count == 1 ? "" : "s")</summary>
                        @foreach (var v in card.OtherVariants)
                        {
                            <div class="lh-variant">
                                <span class="lh-tag lh-tag-quality">@v.QualityLabel</span>
                                @if (!string.IsNullOrEmpty(v.Language)) { <span class="lh-tag">@v.Language</span> }
                                <button class="lh-link" @onclick="() => Send(v.Id)">Send this</button>
                                <button class="lh-link" @onclick="() => Skip(v.Id)">Skip</button>
                            </div>
                        }
                    </details>
                }

                <footer class="lh-card-actions">
                    <button class="lh-secondary" @onclick="() => Skip(card.Chosen.Id)" disabled="@_busyIds.Contains(card.Chosen.Id)">
                        Skip
                    </button>
                    <button class="lh-primary" @onclick="() => Send(card.Chosen.Id)" disabled="@_busyIds.Contains(card.Chosen.Id)">
                        @(_busyIds.Contains(card.Chosen.Id) ? "Sending…" : "Send to NAS")
                    </button>
                </footer>

                @if (_messages.TryGetValue(card.Chosen.Id, out var msg))
                {
                    <p class="lh-action-msg">@msg</p>
                }
            </article>
        }
    }
</div>

@code {
    private List<InboxCard> _cards = new();
    private bool _loading = true;
    private readonly HashSet<int> _busyIds = new();
    private readonly Dictionary<int, string> _messages = new();

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        _loading = true;
        StateHasChanged();
        try { _cards = await Api.GetInboxAsync(); }
        catch { _cards = new(); }
        finally { _loading = false; }
    }

    private async Task ScanNow()
    {
        await Api.TriggerScanAsync();
        _messages[-1] = "Scan requested. Refresh in a few seconds.";
    }

    private async Task Send(int articleId)
    {
        _busyIds.Add(articleId);
        _messages.Remove(articleId);
        StateHasChanged();
        try
        {
            var res = await Api.SendArticleAsync(articleId);
            // The submission is persisted regardless of DSM outcome. On
            // failure, ResponseMessage holds the friendly DsmException.HumanMessage
            // (see SubmissionService); surface it directly instead of the
            // raw exception message we'd previously fall through to.
            if (string.Equals(res.Status, "Failed", StringComparison.OrdinalIgnoreCase))
            {
                _messages[articleId] = string.IsNullOrEmpty(res.Response)
                    ? "Send failed (no detail)."
                    : res.Response;
            }
            else
            {
                _messages[articleId] = $"Sent ({res.Status}, {res.TaskIds.Count} task{(res.TaskIds.Count == 1 ? "" : "s")} created).";
            }
            await Refresh();
        }
        catch (Exception ex)
        {
            _messages[articleId] = "Failed: " + ex.Message;
        }
        finally
        {
            _busyIds.Remove(articleId);
        }
    }

    private async Task Skip(int articleId)
    {
        _busyIds.Add(articleId);
        StateHasChanged();
        try
        {
            await Api.SkipArticleAsync(articleId);
            await Refresh();
        }
        finally { _busyIds.Remove(articleId); }
    }

    private static string FormatKind(InboxCard c) => c.Kind switch
    {
        "Season" when c.SeasonNumber is int n => $"Saison {n}",
        "Movie" => "Movie",
        "Anime" => "Anime",
        _ => c.Kind
    };

    private static string FormatSize(long bytes) => FormatHelpers.FormatSize(bytes);
}
