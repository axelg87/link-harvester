@inject HarvesterApi Api

<div class="lh-inbox">
    <div class="lh-toolbar">
        <span class="lh-count">@_cards.Count item@(_cards.Count == 1 ? "" : "s")</span>
        <button class="lh-secondary" @onclick="Refresh">Refresh</button>
        <button class="lh-primary" @onclick="ScanNow">Scan now</button>
    </div>

    @if (_loading)
    {
        <p class="lh-muted">Loading…</p>
    }
    else if (_cards.Count == 0)
    {
        <div class="lh-empty">
            <p>No new items.</p>
            <p class="lh-muted">Hit "Scan now" to fetch the latest from the sources.</p>
        </div>
    }
    else
    {
        <div class="lh-grid">
            @foreach (var card in _cards)
            {
                <MediaTile
                    Title="@card.DisplayTitle"
                    Poster="@card.Poster"
                    Category="@FormatKind(card)"
                    Year="@card.Year"
                    SeenAt="@card.UpdatedAt"
                    Rating="@card.Rating"
                    Genres="@(card.Genres ?? new())"
                    MetadataUncertain="@card.MetadataUncertain"
                    SourceLabel="ZT"
                    OnOpen="@(() => OpenCatalogTitle(card))" />
            }
        </div>
        @foreach (var msg in _messages.Values)
        {
            <p class="lh-action-msg">@msg</p>
        }
    }
</div>

@if (_selectedTitle is not null)
{
    <TitleDetailModal
        Title="_selectedTitle"
        SelectedLinkIds="_selectedLinkIds"
        Sending="_sending"
        SendOk="_sendOk"
        SendMessage="_sendMessage"
        OnClose="CloseTitle"
        OnToggleLink="@(args => ToggleLink(args.LinkId, args.On))"
        OnSend="SendSelected" />
}

@code {
    private List<InboxCard> _cards = new();
    private bool _loading = true;
    private readonly Dictionary<int, string> _messages = new();
    private TitleDetail? _selectedTitle;
    private HashSet<int> _selectedLinkIds = new();
    private bool _sending;
    private bool _sendOk;
    private string? _sendMessage;

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        _loading = true;
        StateHasChanged();
        try { _cards = await Api.GetInboxAsync(); }
        catch { _cards = new(); }
        finally { _loading = false; }
    }

    private async Task ScanNow()
    {
        await Api.TriggerScanAsync();
        _messages[-1] = "Scan requested. Refresh in a few seconds.";
    }

    private static string FormatKind(InboxCard c) => c.Kind switch
    {
        "Season" when c.SeasonNumber is int n => $"Saison {n}",
        "Movie" => "Movie",
        "Anime" => "Anime",
        _ => c.Kind
    };

    private async Task OpenCatalogTitle(InboxCard card)
    {
        if (card.CatalogTitleId is not int catalogTitleId)
        {
            _messages[card.TitleId] = "This item is still being prepared for the catalog.";
            return;
        }

        try
        {
            var title = await Api.GetTitleAsync(catalogTitleId);
            if (title is null) return;
            _selectedTitle = title;
            _selectedLinkIds = new HashSet<int>();
            var best = (title.Links ?? new())
                .Concat((title.Episodes ?? new()).SelectMany(e => e.Links ?? new()))
                .OrderBy(l => HostRank(l.Host))
                .ThenByDescending(l => l.SizeBytes ?? 0)
                .FirstOrDefault();
            if (best is not null) _selectedLinkIds.Add(best.Id);
        }
        catch (Exception ex)
        {
            _messages[card.TitleId] = "Could not open item: " + ex.Message;
        }
    }

    private void CloseTitle() => _selectedTitle = null;

    private void ToggleLink(int id, bool on)
    {
        if (on) _selectedLinkIds.Add(id); else _selectedLinkIds.Remove(id);
    }

    private async Task SendSelected()
    {
        if (_selectedLinkIds.Count == 0) return;
        _sending = true;
        _sendMessage = null;
        try
        {
            var res = await Api.SendCatalogLinksAsync(_selectedLinkIds);
            _sendOk = res.Ok;
            _sendMessage = res.Ok
                ? $"Sent {res.Submitted} link(s) to DSM ({res.TaskIds.Count} task(s) created)."
                : (res.Error ?? "Send failed.");
            await Refresh();
        }
        catch (Exception ex) { _sendOk = false; _sendMessage = ex.Message; }
        finally { _sending = false; }
    }

    private static int HostRank(string? host)
    {
        if (string.IsNullOrWhiteSpace(host)) return 9;
        var h = host.ToLowerInvariant();
        if (h.Contains("1fichier")) return 0;
        if (h.Contains("rapidgator")) return 1;
        if (h.Contains("uploady")) return 2;
        if (h.Contains("nitroflare")) return 3;
        return 9;
    }
}
