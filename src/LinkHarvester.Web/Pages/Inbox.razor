@inject HarvesterApi Api

<div class="lh-inbox">
    <div class="lh-toolbar">
        <span class="lh-count">@_visibleCards.Count of @_cards.Count</span>
        <button class="lh-secondary" @onclick="Refresh">Refresh</button>
        <button class="lh-primary" @onclick="ScanNow">Scan now</button>
    </div>

    <FilterPanel Title="Filters" OpenByDefault="false" ActiveCount="@InboxActiveFilterCount()">
        <InboxFilters
            Query="@_query"
            Kind="@_kind"
            QueryChanged="@(v => _query = v)"
            KindChanged="@(v => _kind = v)"
            OnChanged="ApplyFilters" />
    </FilterPanel>

    @if (_loading)
    {
        <p class="lh-muted">Loading…</p>
    }
    else if (_cards.Count == 0)
    {
        <div class="lh-empty">
            <p>No new items.</p>
            <p class="lh-muted">Hit "Scan now" to fetch the latest from the sources.</p>
        </div>
    }
    else if (_visibleCards.Count == 0)
    {
        <div class="lh-empty">
            <p>No items match your filters.</p>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_bulkMessage))
        {
            <p class="@(_bulkOk ? "lh-muted" : "lh-error")">@_bulkMessage</p>
        }
        <MediaGrid TItem="InboxCard"
                   @ref="_grid"
                   Items="_visibleCards"
                   ItemId="(c => c.CatalogTitleId ?? c.TitleId)"
                   IsSelectable="(c => c.CatalogTitleId.HasValue)"
                   Sending="_bulkSending"
                   OnItemClick="HandleTileClick"
                   OnSelectionAdded="PrefetchForSelection"
                   OnBulkSend="DoBulkSend">
            <ItemTemplate Context="card">
                <MediaTile
                    Title="@card.DisplayTitle"
                    Poster="@card.Poster"
                    Category="@FormatKind(card)"
                    Year="@card.Year"
                    Rating="@card.Rating"
                    Genres="@(card.Genres ?? new())"
                    MetadataUncertain="@card.MetadataUncertain"
                    SourceLabel="ZT" />
            </ItemTemplate>
        </MediaGrid>
        @foreach (var msg in _messages.Values)
        {
            <p class="lh-action-msg">@msg</p>
        }
    }
</div>

<TitleModalHost @ref="_modal" OnSendComplete="Refresh" />

@code {
    private List<InboxCard> _cards = new();
    private List<InboxCard> _visibleCards = new();
    private string? _query;
    private string? _kind;
    private bool _loading = true;
    private readonly Dictionary<int, string> _messages = new();

    private TitleModalHost _modal = default!;
    private MediaGrid<InboxCard> _grid = default!;
    private bool _bulkSending;
    private string? _bulkMessage;
    private bool _bulkOk;

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        _loading = true;
        StateHasChanged();
        try { _cards = await Api.GetInboxAsync(); }
        catch { _cards = new(); }
        finally { _loading = false; ApplyFilters(); }
    }

    private void ApplyFilters()
    {
        IEnumerable<InboxCard> q = _cards;
        if (!string.IsNullOrWhiteSpace(_query))
        {
            var needle = _query.Trim();
            q = q.Where(c => c.DisplayTitle.Contains(needle, StringComparison.OrdinalIgnoreCase));
        }
        if (!string.IsNullOrWhiteSpace(_kind))
            q = q.Where(c => string.Equals(c.Kind, _kind, StringComparison.OrdinalIgnoreCase));
        _visibleCards = q.ToList();
        StateHasChanged();
    }

    private int InboxActiveFilterCount()
        => (!string.IsNullOrWhiteSpace(_query) ? 1 : 0) + (!string.IsNullOrWhiteSpace(_kind) ? 1 : 0);

    private async Task ScanNow()
    {
        await Api.TriggerScanAsync();
        _messages[-1] = "Scan requested. Refresh in a few seconds.";
    }

    private static string FormatKind(InboxCard c) => c.Kind switch
    {
        "Season" when c.SeasonNumber is int n => $"Saison {n}",
        "Movie" => "Movie",
        "Anime" => "Anime",
        _ => c.Kind
    };

    private async Task HandleTileClick(int catalogTitleId)
    {
        // The MediaGrid item id is `card.CatalogTitleId ?? card.TitleId`; if
        // the card hasn't been promoted yet, IsSelectable returns false but a
        // tap still flows through here. Surface the message inline rather than
        // opening an empty modal.
        var card = _cards.FirstOrDefault(c => (c.CatalogTitleId ?? c.TitleId) == catalogTitleId);
        if (card is null) return;
        if (card.CatalogTitleId is null)
        {
            _messages[card.TitleId] = "This item is still being prepared for the catalog.";
            return;
        }
        try { await _modal.OpenAsync(card.CatalogTitleId.Value); }
        catch (Exception ex) { _messages[card.TitleId] = "Could not open item: " + ex.Message; }
    }

    private async Task PrefetchForSelection(IReadOnlyCollection<int> newIds)
    {
        foreach (var id in newIds)
            await _modal.PrefetchInventoryAsync(id);
    }

    private async Task DoBulkSend(IReadOnlyCollection<int> ids)
    {
        if (ids.Count == 0) return;
        _bulkSending = true;
        _bulkMessage = null;
        StateHasChanged();
        try
        {
            var jobs = ids.Select(async id =>
            {
                if (!_modal.TitleCache.ContainsKey(id) || !_modal.InventoryCache.ContainsKey(id))
                    await _modal.PrefetchInventoryAsync(id);
                var title = await _modal.TitleCache[id];
                InventoryResult? inv = null;
                try { inv = await _modal.InventoryCache[id]; } catch { }
                return (id, title, inv);
            }).ToList();
            var resolved = await Task.WhenAll(jobs);

            var linkIds = new HashSet<int>();
            var skippedAllOwned = 0;
            foreach (var (id, title, inv) in resolved)
            {
                if (title is null) continue;
                var owned = TitleModalHost.ParseOwnedEpisodes(inv);
                var ids2 = ResolveMissingLinkIds(title, owned);
                if (ids2.Count == 0) { skippedAllOwned++; continue; }
                foreach (var lid in ids2) linkIds.Add(lid);
            }
            if (linkIds.Count == 0)
            {
                _bulkOk = true;
                _bulkMessage = "Nothing to send (all items already on disk).";
                return;
            }

            var res = await Api.SendCatalogLinksAsync(linkIds);
            _bulkOk = res.Ok;
            _bulkMessage = res.Ok
                ? $"Sent {res.Submitted} link(s)."
                    + (skippedAllOwned > 0 ? $" Skipped {skippedAllOwned} already-complete title(s)." : "")
                : (res.Error ?? "Send failed.");
            if (res.Ok)
            {
                _modal.ClearInventoryCache();
                _grid.Reset();
                await Refresh();
            }
        }
        catch (Exception ex)
        {
            _bulkOk = false;
            _bulkMessage = ex.Message;
        }
        finally
        {
            _bulkSending = false;
            StateHasChanged();
        }
    }

    // Single source of truth: BestLinkId comes from the server (computed
    // by BestVariantPicker against the user's settings). The client never
    // re-ranks. Before this, the client used a HostRank+SizeBytes sort that
    // disagreed with /api/catalog/lookup's BestVariantPicker output — the
    // search-bar SEND would pick 1080p while the modal pre-selected 4K for
    // the same title.
    private static List<int> ResolveMissingLinkIds(TitleDetail title, HashSet<(int s, int e)> owned)
    {
        var ids = new List<int>();
        var episodes = title.Episodes ?? new();
        if (episodes.Count > 0)
        {
            foreach (var ep in episodes)
            {
                var isOwned = ep.IsFullSeason
                    ? owned.Any(o => o.s == ep.SeasonNumber)
                    : owned.Contains((ep.SeasonNumber, ep.EpisodeNumber));
                if (isOwned) continue;
                if (ep.BestLinkId is int eid) ids.Add(eid);
            }
        }
        else if (title.BestLinkId is int tid)
        {
            ids.Add(tid);
        }
        return ids;
    }
}
