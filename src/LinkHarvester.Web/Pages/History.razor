@page "/history"
@inject HarvesterApi Api

<PageTitle>Send history</PageTitle>

<div class="lh-catalog">
    <header class="lh-catalog-head">
        <a class="lh-link" href="/">← Inbox</a>
        <h1>Send history</h1>
    </header>

    <div class="lh-history-filters">
        @foreach (var status in _statusFilters)
        {
            <button class="@FilterClass(_status, status.Value)" @onclick="() => SetStatus(status.Value)">@status.Label</button>
        }
        @foreach (var source in _sourceFilters)
        {
            <button class="@FilterClass(_source, source.Value)" @onclick="() => SetSource(source.Value)">@source.Label</button>
        }
    </div>

    @if (_loading)
    {
        <p class="lh-muted">Loading…</p>
    }
    else if (_page is null || _page.Items.Count == 0)
    {
        <p class="lh-muted">No send attempts yet.</p>
    }
    else
    {
        <div class="lh-history-list">
            @foreach (var item in _page.Items)
            {
                <article class="lh-history-card">
                    <div class="lh-history-main">
                        <div class="lh-history-title">@item.DisplayTitle</div>
                        <div class="lh-history-meta">
                            <span class="lh-tag">@SourceLabel(item.Source)</span>
                            <span class="@StatusClass(item.Status)">@item.Status</span>
                            <span>@item.UrlCount link@(item.UrlCount == 1 ? "" : "s")</span>
                            <span>@item.SubmittedAt.ToLocalTime().ToString("dd/MM HH:mm")</span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(item.ResponseMessage))
                    {
                        <div class="lh-history-error">@item.ResponseMessage</div>
                    }
                    <button class="lh-secondary" @onclick="() => Resend(item.Id)" disabled="@_resending.Contains(item.Id)">
                        @(_resending.Contains(item.Id) ? "Resending…" : "Resend")
                    </button>
                </article>
            }
        </div>
        <div class="lh-pager">
            <button class="lh-secondary" @onclick="PrevPage" disabled="@(_page.Page <= 1)">← Prev</button>
            <span class="lh-muted">Page @_page.Page / @TotalPages</span>
            <button class="lh-secondary" @onclick="NextPage" disabled="@(_page.Page >= TotalPages)">Next →</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="@(_messageOk ? "lh-muted" : "lh-error")">@_message</p>
    }
</div>

@code {
    private SendHistoryPage? _page;
    private bool _loading = true;
    private string? _status;
    private string? _source;
    private int _pageNumber = 1;
    private readonly HashSet<int> _resending = new();
    private string? _message;
    private bool _messageOk;
    private readonly (string Label, string? Value)[] _statusFilters =
    [
        ("All", null),
        ("Sent", "Sent"),
        ("Failed", "Failed"),
        ("Resolution failed", "ResolutionFailed"),
        ("Pending", "Pending")
    ];
    private readonly (string Label, string? Value)[] _sourceFilters =
    [
        ("All sources", null),
        ("ZT", "ZtArticle"),
        ("Catalog", "Catalog")
    ];

    private int TotalPages => _page is null || _page.PageSize == 0 ? 1 : Math.Max(1, (int)Math.Ceiling(_page.Total / (double)_page.PageSize));

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        _loading = true;
        try { _page = await Api.GetSendHistoryAsync(_status, _source, _pageNumber); }
        finally { _loading = false; }
    }

    private async Task SetStatus(string? status)
    {
        _status = status;
        _pageNumber = 1;
        await Refresh();
    }

    private async Task SetSource(string? source)
    {
        _source = source;
        _pageNumber = 1;
        await Refresh();
    }

    private async Task NextPage()
    {
        if (_page is null || _page.Page >= TotalPages) return;
        _pageNumber++;
        await Refresh();
    }

    private async Task PrevPage()
    {
        if (_pageNumber <= 1) return;
        _pageNumber--;
        await Refresh();
    }

    private async Task Resend(int id)
    {
        _resending.Add(id);
        _message = null;
        try
        {
            var result = await Api.ResendAsync(id);
            _messageOk = string.Equals(result.Status, "Sent", StringComparison.OrdinalIgnoreCase);
            _message = _messageOk
                ? $"Resent as attempt #{result.SubmissionId} ({result.TaskIds.Count} task(s))."
                : $"Resend failed: {result.Response ?? result.Status}";
            await Refresh();
        }
        catch (Exception ex)
        {
            _messageOk = false;
            _message = ex.Message;
        }
        finally
        {
            _resending.Remove(id);
        }
    }

    private static string FilterClass(string? current, string? value) =>
        string.Equals(current ?? "", value ?? "", StringComparison.Ordinal) ? "lh-chip lh-chip-on" : "lh-chip";

    private static string SourceLabel(string source) =>
        string.Equals(source, "ZtArticle", StringComparison.OrdinalIgnoreCase) ? "ZT" : source;

    private static string StatusClass(string status) =>
        string.Equals(status, "Sent", StringComparison.OrdinalIgnoreCase) ? "lh-test-ok" : "lh-test-err";
}
