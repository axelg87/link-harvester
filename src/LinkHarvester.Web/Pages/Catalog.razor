@page "/catalog"
@inject HarvesterApi Api
@inject NavigationManager Nav

<PageTitle>Catalog</PageTitle>

@*
    Page-level coordination only:
      - First-load: fetch /stats, /facets, /genres, then run a default search.
      - Search debounce + pagination.
      - Modal lifecycle (open/close + best-link preselect).
      - Send-to-NAS hand-off.
    The filter sidebar and the title-detail modal each have their own
    components under Web/Components/Catalog/.
*@

<div class="lh-catalog">
    <header class="lh-catalog-head">
        <a class="lh-link" href="/">← Inbox</a>
        <h1>Catalog</h1>
        @if (_stats is not null)
        {
            <span class="lh-muted">@_stats.Titles.ToString("N0") titles · @_stats.Links.ToString("N0") links · @_stats.Enriched.ToString("N0") enriched</span>
        }
    </header>

    <div class="lh-catalog-body">
        <CatalogFilters
            Query="_query"
            Facets="_facets"
            Genres="_genres"
            SizeMinGb="_sizeMinGb"
            SizeMaxGb="_sizeMaxGb"
            SizeMinGbChanged="@(v => _sizeMinGb = v)"
            SizeMaxGbChanged="@(v => _sizeMaxGb = v)"
            OnSearchChanged="ScheduleSearch"
            OnCategoryChanged="SetCategory"
            OnClearFilters="ClearAllFilters" />

        <section class="lh-results">
            <div class="lh-results-bar">
                <span class="lh-muted">@(_page?.Total.ToString("N0") ?? "—") results</span>
                <div class="lh-sort">
                    <label>Sort:</label>
                    <select @bind="_query.Sort" @bind:after="ScheduleSearch">
                        <option value="popularity">Popularity</option>
                        <option value="year">Year (newest)</option>
                        <option value="rating">Rating</option>
                        <option value="title">Title A-Z</option>
                    </select>
                </div>
            </div>

            @if (_searching)
            {
                <p class="lh-muted">Searching…</p>
            }
            else if (_page is null || _page.Items.Count == 0)
            {
                <div class="lh-empty">
                    <p>No results.</p>
                    <p class="lh-muted">Try clearing some filters.</p>
                </div>
            }
            else
            {
                <div class="lh-grid">
                    @foreach (var hit in _page.Items)
                    {
                        <article class="lh-tile" @onclick="() => OpenTitle(hit.Id)">
                            <div class="lh-poster">
                                @if (!string.IsNullOrEmpty(hit.Poster))
                                {
                                    <img loading="lazy" src="@hit.Poster" alt="@hit.Title" />
                                }
                                else
                                {
                                    <div class="lh-poster-fallback">@hit.Category</div>
                                }
                                @if (hit.Rating.HasValue)
                                {
                                    <span class="lh-rating">@hit.Rating.Value.ToString("0.0")</span>
                                }
                            </div>
                            <div class="lh-tile-body">
                                <div class="lh-tile-title">@hit.Title</div>
                                <div class="lh-tile-meta">
                                    @if (hit.Year.HasValue) { <span>@hit.Year</span> }
                                    <span class="lh-tag">@hit.Category</span>
                                </div>
                                @if (hit.Genres.Count > 0)
                                {
                                    <div class="lh-tile-genres">@string.Join(" · ", hit.Genres.Take(3))</div>
                                }
                            </div>
                        </article>
                    }
                </div>

                <div class="lh-pager">
                    <button class="lh-secondary" @onclick="PrevPage" disabled="@(_query.Page <= 1)">← Prev</button>
                    <span class="lh-muted">Page @_query.Page / @TotalPages</span>
                    <button class="lh-secondary" @onclick="NextPage" disabled="@(_query.Page >= TotalPages)">Next →</button>
                </div>
            }
        </section>
    </div>
</div>

@if (_selectedTitle is not null)
{
    <TitleDetailModal
        Title="_selectedTitle"
        SelectedLinkIds="_selectedLinkIds"
        Sending="_sending"
        SendOk="_sendOk"
        SendMessage="_sendMessage"
        OnClose="CloseTitle"
        OnToggleLink="@(args => ToggleLink(args.LinkId, args.On))"
        OnSend="SendSelected" />
}

@code {
    private CatalogStats? _stats;
    private CatalogFacets? _facets;
    private List<FacetEntry> _genres = new();
    private CatalogSearchQuery _query = new() { Sort = "popularity", PageSize = 50 };
    private SearchPage? _page;
    private double? _sizeMinGb;
    private double? _sizeMaxGb;
    private bool _searching;
    private CancellationTokenSource? _debounce;

    private TitleDetail? _selectedTitle;
    private HashSet<int> _selectedLinkIds = new();
    private bool _sending;
    private bool _sendOk;
    private string? _sendMessage;
    // Separate from _sendMessage so a transient search error doesn't appear
    // inside the open title-detail modal where it makes no sense.
    private string? _searchError;

    private int TotalPages => _page is null || _page.PageSize == 0 ? 1 : Math.Max(1, (int)Math.Ceiling(_page.Total / (double)_page.PageSize));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stats = await Api.GetCatalogStatsAsync();
            _facets = await Api.GetCatalogFacetsAsync();
            _genres = await Api.GetCatalogGenresAsync();
        }
        catch { /* unauthenticated -> redirect handled by layout */ }
        await DoSearch();
    }

    private async Task DoSearch()
    {
        _searching = true;
        StateHasChanged();
        try
        {
            _page = await Api.SearchCatalogAsync(_query);
            _searchError = null;
        }
        catch (Exception ex) { _searchError = ex.Message; }
        finally { _searching = false; }
    }

    private Task ScheduleSearch()
    {
        // Cancel the previous pending debounce so rapid filter changes only
        // run the latest one. Capture a new CTS that we own for this call.
        _debounce?.Cancel();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        return InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(250, token);
                _query.Page = 1;
                // Refresh size-derived query fields before searching. The
                // CatalogFilters component already pushed _sizeMin/MaxGb back
                // to us via callbacks; we convert here.
                _query.SizeMinBytes = _sizeMinGb.HasValue ? (long)(_sizeMinGb.Value * 1024 * 1024 * 1024) : null;
                _query.SizeMaxBytes = _sizeMaxGb.HasValue ? (long)(_sizeMaxGb.Value * 1024 * 1024 * 1024) : null;
                await DoSearch();
            }
            catch (TaskCanceledException) { /* superseded by a newer search */ }
        });
    }

    private async Task SetCategory(string? cat)
    {
        _query.Category = cat;
        _query.Page = 1;
        await DoSearch();
    }

    private async Task NextPage()
    {
        if (_query.Page < TotalPages) { _query.Page++; await DoSearch(); }
    }

    private async Task PrevPage()
    {
        if (_query.Page > 1) { _query.Page--; await DoSearch(); }
    }

    private async Task ClearAllFilters()
    {
        _query = new CatalogSearchQuery { Sort = _query.Sort, PageSize = _query.PageSize };
        _sizeMinGb = null; _sizeMaxGb = null;
        await DoSearch();
    }

    private async Task OpenTitle(int id)
    {
        _selectedTitle = await Api.GetTitleAsync(id);
        _selectedLinkIds = new HashSet<int>();
        _sendMessage = null;
        // Pre-select the best link by hoster priority (1fichier > rapidgator > …)
        // and largest size.
        if (_selectedTitle is not null)
        {
            var best = _selectedTitle.Links
                .Concat(_selectedTitle.Episodes.SelectMany(e => e.Links))
                .OrderBy(l => HostRank(l.Host))
                .ThenByDescending(l => l.SizeBytes ?? 0)
                .FirstOrDefault();
            if (best is not null) _selectedLinkIds.Add(best.Id);
        }
    }

    private void CloseTitle() => _selectedTitle = null;

    private void ToggleLink(int id, bool on)
    {
        if (on) _selectedLinkIds.Add(id); else _selectedLinkIds.Remove(id);
    }

    private async Task SendSelected()
    {
        if (_selectedLinkIds.Count == 0) return;
        _sending = true;
        _sendMessage = null;
        try
        {
            var res = await Api.SendCatalogLinksAsync(_selectedLinkIds);
            _sendOk = res.Ok;
            _sendMessage = res.Ok
                ? $"Sent {res.Submitted} link(s) to DSM ({res.TaskIds.Count} task(s) created)."
                : (res.Error ?? "Send failed.");
        }
        catch (Exception ex) { _sendOk = false; _sendMessage = ex.Message; }
        finally { _sending = false; }
    }

    // Hoster pre-select ordering. Hardcoded for now; the audit flagged that
    // this should read user-configured HosterPriority instead, but plumbing
    // settings through the catalog page is a separate change.
    private static int HostRank(string host)
    {
        var h = host.ToLowerInvariant();
        if (h.Contains("1fichier")) return 0;
        if (h.Contains("rapidgator")) return 1;
        if (h.Contains("uploady")) return 2;
        if (h.Contains("nitroflare")) return 3;
        return 9;
    }
}
