@page "/catalog"
@inject HarvesterApi Api
@inject NavigationManager Nav

<PageTitle>Catalog</PageTitle>

@*
    Page-level coordination only:
      - First-load: fetch /stats, /facets, /genres, then run a default search.
      - Search debounce + pagination.
      - Hand-off to MediaGrid for tiles + multi-select + bulk send.
      - Hand-off to TitleModalHost for the detail modal.
*@

<div class="lh-catalog">
    <header class="lh-catalog-head">
        <a class="lh-link" href="/">← Inbox</a>
        <h1>Catalog</h1>
        @if (_stats is not null)
        {
            <span class="lh-muted">@_stats.Titles.ToString("N0") titles · @_stats.Links.ToString("N0") links · @_stats.Enriched.ToString("N0") enriched</span>
        }
    </header>

    <div class="lh-catalog-body">
        <CatalogFilters
            Query="_query"
            Facets="_facets"
            Genres="_genres"
            SizeMinGb="_sizeMinGb"
            SizeMaxGb="_sizeMaxGb"
            SizeMinGbChanged="@(v => _sizeMinGb = v)"
            SizeMaxGbChanged="@(v => _sizeMaxGb = v)"
            OnSearchChanged="ScheduleSearch"
            OnCategoryChanged="SetCategory"
            OnClearFilters="ClearAllFilters" />

        <section class="lh-results">
            <div class="lh-results-bar">
                <span class="lh-muted">@(_page?.Total.ToString("N0") ?? "—") results</span>
                <div class="lh-sort">
                    <label>Sort:</label>
                    <select @bind="_query.Sort" @bind:after="ScheduleSearch">
                        <option value="popularity">Popularity</option>
                        <option value="year">Year (newest)</option>
                        <option value="rating">Rating</option>
                        <option value="title">Title A-Z</option>
                    </select>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_titleError))
            {
                <p class="lh-error">@_titleError</p>
            }
            @if (!string.IsNullOrEmpty(_bulkMessage))
            {
                <p class="@(_bulkOk ? "lh-muted" : "lh-error")">@_bulkMessage</p>
            }

            @if (_searching)
            {
                <p class="lh-muted">Searching…</p>
            }
            else if (_page is null || _page.Items.Count == 0)
            {
                <div class="lh-empty">
                    <p>No results.</p>
                    <p class="lh-muted">Try clearing some filters.</p>
                </div>
            }
            else
            {
                <MediaGrid TItem="SearchHit"
                           @ref="_grid"
                           Items="_page.Items"
                           ItemId="(h => h.Id)"
                           Sending="_bulkSending"
                           OnItemClick="OpenTitle"
                           OnSelectionAdded="PrefetchForSelection"
                           OnBulkSend="DoBulkSend">
                    <ItemTemplate Context="hit">
                        <MediaTile
                            Title="@hit.Title"
                            Poster="@hit.Poster"
                            Category="@hit.Category"
                            Year="@hit.Year"
                            Rating="@hit.Rating"
                            Genres="@(hit.Genres ?? new())"
                            MetadataUncertain="@hit.MetadataUncertain"
                            SeasonNumber="@hit.SeasonNumber" />
                    </ItemTemplate>
                </MediaGrid>

                <div class="lh-pager">
                    <button class="lh-secondary" @onclick="PrevPage" disabled="@(_query.Page <= 1)">← Prev</button>
                    <span class="lh-muted">Page @_query.Page / @TotalPages</span>
                    <button class="lh-secondary" @onclick="NextPage" disabled="@(_query.Page >= TotalPages)">Next →</button>
                </div>
            }
        </section>
    </div>
</div>

<TitleModalHost @ref="_modal" />

@code {
    private CatalogStats? _stats;
    private CatalogFacets? _facets;
    private List<FacetEntry> _genres = new();
    private CatalogSearchQuery _query = new() { Sort = "popularity", PageSize = 50 };
    private SearchPage? _page;
    private double? _sizeMinGb;
    private double? _sizeMaxGb;
    private bool _searching;
    private CancellationTokenSource? _debounce;

    private TitleModalHost _modal = default!;
    private MediaGrid<SearchHit> _grid = default!;
    private string? _searchError;
    private string? _titleError;

    private bool _bulkSending;
    private string? _bulkMessage;
    private bool _bulkOk;

    private int TotalPages => _page is null || _page.PageSize == 0 ? 1 : Math.Max(1, (int)Math.Ceiling(_page.Total / (double)_page.PageSize));

    protected override async Task OnInitializedAsync()
    {
        await DoSearch();
        _ = LoadCatalogChrome();
    }

    private async Task LoadCatalogChrome()
    {
        try
        {
            _stats = await Api.GetCatalogStatsAsync();
            _facets = await Api.GetCatalogFacetsAsync();
            _genres = await Api.GetCatalogGenresAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch { /* unauthenticated -> redirect handled by layout */ }
    }

    private async Task DoSearch()
    {
        _searching = true;
        StateHasChanged();
        try
        {
            _page = await Api.SearchCatalogAsync(_query);
            _searchError = null;
        }
        catch (Exception ex) { _searchError = ex.Message; }
        finally { _searching = false; }
    }

    private Task ScheduleSearch()
    {
        _debounce?.Cancel();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        return InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(250, token);
                _query.Page = 1;
                _query.SizeMinBytes = _sizeMinGb.HasValue ? (long)(_sizeMinGb.Value * 1024 * 1024 * 1024) : null;
                _query.SizeMaxBytes = _sizeMaxGb.HasValue ? (long)(_sizeMaxGb.Value * 1024 * 1024 * 1024) : null;
                await DoSearch();
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task SetCategory(string? cat)
    {
        _query.Category = cat;
        _query.Page = 1;
        await DoSearch();
    }

    private async Task NextPage()
    {
        if (_query.Page < TotalPages) { _query.Page++; await DoSearch(); }
    }

    private async Task PrevPage()
    {
        if (_query.Page > 1) { _query.Page--; await DoSearch(); }
    }

    private async Task ClearAllFilters()
    {
        _query = new CatalogSearchQuery { Sort = _query.Sort, PageSize = _query.PageSize };
        _sizeMinGb = null; _sizeMaxGb = null;
        await DoSearch();
    }

    private async Task OpenTitle(int id)
    {
        _titleError = null;
        try { await _modal.OpenAsync(id); }
        catch (Exception ex) { _titleError = "Could not open title: " + ex.Message; }
    }

    // Each newly-selected tile pre-warms its title+inventory in the modal host
    // so when the user hits "Send N" we already have what we need.
    private async Task PrefetchForSelection(IReadOnlyCollection<int> newIds)
    {
        foreach (var id in newIds)
            await _modal.PrefetchInventoryAsync(id);
    }

    private async Task DoBulkSend(IReadOnlyCollection<int> ids)
    {
        if (ids.Count == 0) return;
        _bulkSending = true;
        _bulkMessage = null;
        StateHasChanged();
        try
        {
            // Wait for any inflight prefetches; resolve title+inventory per id.
            var jobs = ids.Select(async id =>
            {
                var titleTask = _modal.TitleCache.TryGetValue(id, out var t) ? t : null;
                var invTask = _modal.InventoryCache.TryGetValue(id, out var i) ? i : null;
                if (titleTask is null || invTask is null)
                {
                    await _modal.PrefetchInventoryAsync(id);
                    titleTask = _modal.TitleCache[id];
                    invTask = _modal.InventoryCache[id];
                }
                var title = await titleTask;
                InventoryResult? inv = null;
                try { inv = await invTask; }
                catch { /* treat as no-inventory */ }
                return (id, title, inv);
            }).ToList();
            var resolved = await Task.WhenAll(jobs);

            var linkIds = new HashSet<int>();
            var skippedAllOwned = 0;
            var skippedNoData = 0;
            foreach (var (id, title, inv) in resolved)
            {
                if (title is null) { skippedNoData++; continue; }
                var owned = TitleModalHost.ParseOwnedEpisodes(inv);
                var ids2 = ResolveMissingLinkIds(title, owned);
                if (ids2.Count == 0) { skippedAllOwned++; continue; }
                foreach (var lid in ids2) linkIds.Add(lid);
            }
            if (linkIds.Count == 0)
            {
                _bulkOk = true;
                _bulkMessage = skippedAllOwned > 0
                    ? $"Nothing to send: {skippedAllOwned} title(s) already complete on disk."
                    : "Nothing to send.";
                return;
            }

            var res = await Api.SendCatalogLinksAsync(linkIds);
            _bulkOk = res.Ok;
            _bulkMessage = res.Ok
                ? $"Sent {res.Submitted} link(s) across {resolved.Length - skippedAllOwned - skippedNoData} title(s). "
                    + (skippedAllOwned > 0 ? $"Skipped {skippedAllOwned} already-complete title(s)." : "")
                : (res.Error ?? "Send failed.");
            if (res.Ok)
            {
                _modal.ClearInventoryCache();
                _grid.Reset();
            }
        }
        catch (Exception ex)
        {
            _bulkOk = false;
            _bulkMessage = ex.Message;
        }
        finally
        {
            _bulkSending = false;
            StateHasChanged();
        }
    }

    private static List<int> ResolveMissingLinkIds(TitleDetail title, HashSet<(int s, int e)> owned)
    {
        var ids = new List<int>();
        var episodes = title.Episodes ?? new();
        if (episodes.Count > 0)
        {
            foreach (var ep in episodes)
            {
                var isOwned = ep.IsFullSeason
                    ? owned.Any(o => o.s == ep.SeasonNumber)
                    : owned.Contains((ep.SeasonNumber, ep.EpisodeNumber));
                if (isOwned) continue;
                var best = (ep.Links ?? new())
                    .OrderBy(l => TitleModalHost.HostRank(l.Host))
                    .ThenByDescending(l => l.SizeBytes ?? 0)
                    .FirstOrDefault();
                if (best is not null) ids.Add(best.Id);
            }
        }
        else
        {
            var best = (title.Links ?? new())
                .OrderBy(l => TitleModalHost.HostRank(l.Host))
                .ThenByDescending(l => l.SizeBytes ?? 0)
                .FirstOrDefault();
            if (best is not null) ids.Add(best.Id);
        }
        return ids;
    }
}
