@page "/"
@inject NavigationManager Nav
@inject HarvesterApi Api

<PageTitle>Inbox</PageTitle>

@if (!_ready)
{
    <p class="lh-muted">Loading…</p>
}
else if (!_authed)
{
    <p class="lh-muted">Redirecting…</p>
}
else
{
    <Inbox />
}

@code {
    private bool _ready;
    private bool _authed;

    protected override async Task OnInitializedAsync()
    {
        _authed = await Api.IsAuthenticatedAsync();
        _ready = true;
        if (!_authed) Nav.NavigateTo("/login");
    }
}
