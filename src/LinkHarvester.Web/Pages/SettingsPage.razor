@page "/settings"
@implements IDisposable
@inject HarvesterApi Api
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JsRuntime

<PageTitle>Settings</PageTitle>

@*
    Page-level coordination only. Every settings group is its own component
    in Web/Components/Settings/; this file owns:
      - Loading + saving (single EditForm + Save submit).
      - Catalog/ingestion status polling on a timer.
      - Cross-section transient state (test result, reset confirmation
        dialog, busy flags).
    The previous all-in-one version was 477 lines; this one is ~120.
*@

<div class="lh-settings">
    <div class="lh-settings-head">
        <a href="/" class="lh-link">← Inbox</a>
        <h1>Settings</h1>
    </div>

    @if (_loading)
    {
        <p class="lh-muted">Loading…</p>
    }
    else if (_form is null)
    {
        <p class="lh-error">Failed to load settings.</p>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="Save">
            <SynologySettingsSection
                Form="_form"
                Existing="_existing"
                TestResult="_testResult"
                Busy="_busy"
                Testing="_testing"
                OnTestSynology="TestSynology" />

            <ScanSettingsSection Form="_form" />

            <HosterPrioritySection Form="_form" />

            <TmdbEnrichmentSection
                Form="_form"
                Stats="_catalogStats"
                Resetting="_resetting"
                ResetIsError="_resetIsError"
                ResetMessage="_resetMessage"
                OnRetryTransient="RetryTransientFailures"
                OnRetryAll="RetryAllFailures" />

            <CatalogImportSection
                ImportUrl="_importUrl"
                ImportUrlChanged="@(v => _importUrl = v)"
                Uploading="_uploading"
                UploadedBytes="_uploadedBytes"
                Ingestion="_ingestion"
                OnStartImportFromUrl="StartImportFromUrl"
                OnFilePicked="OnFilePicked"
                OnCancelImport="CancelImport" />

            <LoginSection Form="_form" />

            @if (_message is not null)
            {
                <p class="@(_isError ? "lh-error" : "lh-muted")">@_message</p>
            }

            <div class="lh-card-actions">
                <button class="lh-primary" type="submit" disabled="@_busy">
                    @(_busy ? "Saving…" : "Save")
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _testing;
    private bool _isError;
    private string? _message;
    private SynologyTestResult? _testResult;
    private Settings? _existing;
    private SettingsFormModel? _form;

    private CatalogStats? _catalogStats;
    private IngestionStatus? _ingestion;
    private string _importUrl = string.Empty;
    private bool _uploading;
    private long _uploadedBytes;
    private System.Threading.Timer? _poller;
    private bool _resetting;
    private bool _resetIsError;
    private string? _resetMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existing = await Api.GetSettingsAsync();
            _form = SettingsFormModel.From(_existing);
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _isError = true;
        }
        finally { _loading = false; }
        await RefreshCatalogStatus();
        _poller = new System.Threading.Timer(async _ =>
        {
            try { await InvokeAsync(RefreshCatalogStatus); }
            catch { /* ignore transient polling errors */ }
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    public void Dispose() => _poller?.Dispose();

    private async Task RefreshCatalogStatus()
    {
        try
        {
            _catalogStats = await Api.GetCatalogStatsAsync();
            _ingestion = await Api.GetIngestionStatusAsync();
            StateHasChanged();
        }
        catch { /* unauth or transient */ }
    }

    private async Task StartImportFromUrl()
    {
        if (string.IsNullOrWhiteSpace(_importUrl)) return;
        try
        {
            await Api.ImportFromUrlAsync(_importUrl);
            _message = "Import started. Watch progress below.";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = "Failed to start import: " + ex.Message;
            _isError = true;
        }
        await RefreshCatalogStatus();
    }

    private async Task OnFilePicked(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        _uploading = true;
        _uploadedBytes = 0;
        try
        {
            await using var src = file.OpenReadStream(maxAllowedSize: long.MaxValue);
            var counter = new CountingReadStream(src, n => _uploadedBytes += n);
            var resp = await Api.UploadCatalogFileAsync(counter, file.Name);
            if (!resp.IsSuccessStatusCode)
            {
                _message = $"Upload failed: HTTP {(int)resp.StatusCode}";
                _isError = true;
            }
            else
            {
                _message = "Upload received. Ingestion started.";
                _isError = false;
            }
        }
        catch (Exception ex)
        {
            _message = "Upload failed: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _uploading = false;
            await RefreshCatalogStatus();
        }
    }

    private async Task CancelImport()
    {
        await Api.CancelIngestionAsync();
        await RefreshCatalogStatus();
    }

    private Task RetryTransientFailures() => RetryFailures(
        onlyLockErrors: true,
        confirmMessage: $"Reset {_catalogStats?.EnrichmentFailedTransient ?? 0} transient failures (lock/timeout) to pending? They'll be retried on the next batch.");

    private Task RetryAllFailures() => RetryFailures(
        onlyLockErrors: false,
        confirmMessage: $"Reset ALL {_catalogStats?.EnrichmentFailed ?? 0} failed enrichments to pending? Some of these may genuinely have no TMDB match — retrying will burn TMDB calls on them.");

    private async Task RetryFailures(bool onlyLockErrors, string confirmMessage)
    {
        var ok = await JsRuntime.InvokeAsync<bool>("confirm", confirmMessage);
        if (!ok) return;

        _resetting = true;
        _resetMessage = null;
        try
        {
            var result = await Api.ResetFailedEnrichmentsAsync(onlyLockErrors);
            _resetMessage = $"Reset {result.Reset:N0} failed enrichments to pending.";
            _resetIsError = false;
            await RefreshCatalogStatus();
        }
        catch (Exception ex)
        {
            _resetMessage = "Failed to reset: " + ex.Message;
            _resetIsError = true;
        }
        finally
        {
            _resetting = false;
        }
    }

    private async Task Save()
    {
        if (_form is null) return;
        _busy = true;
        _message = null;
        try
        {
            await Api.SaveSettingsAsync(_form.ToUpdate());
            _existing = await Api.GetSettingsAsync();
            _form = SettingsFormModel.From(_existing);
            _message = "Saved.";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = "Failed: " + ex.Message;
            _isError = true;
        }
        finally { _busy = false; }
    }

    private async Task TestSynology()
    {
        _testing = true;
        _testResult = null;
        try { _testResult = await Api.TestSynologyAsync(); }
        catch (Exception ex) { _testResult = new SynologyTestResult(false, ex.Message); }
        finally { _testing = false; }
    }
}
