@page "/settings"
@implements IDisposable
@inject HarvesterApi Api
@inject NavigationManager Nav

<PageTitle>Settings</PageTitle>

<div class="lh-settings">
    <div class="lh-settings-head">
        <a href="/" class="lh-link">← Inbox</a>
        <h1>Settings</h1>
    </div>

    @if (_loading)
    {
        <p class="lh-muted">Loading…</p>
    }
    else if (_form is null)
    {
        <p class="lh-error">Failed to load settings.</p>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="Save">
            <section class="lh-section">
                <h2>Synology DownloadStation</h2>
                <p class="lh-muted">Where the "Send to NAS" button submits to.</p>

                <label class="lh-field">
                    <span>Base URL</span>
                    <InputText @bind-Value="_form.SynologyBaseUrl" placeholder="http://your-nas.local:5000" />
                </label>
                <label class="lh-field">
                    <span>Username</span>
                    <InputText @bind-Value="_form.SynologyUsername" autocomplete="off" />
                </label>
                <label class="lh-field">
                    <span>Password @(_existing?.SynologyPasswordSet == true ? "(leave blank to keep)" : "")</span>
                    <InputText @bind-Value="_form.SynologyPassword" type="password" autocomplete="new-password" />
                </label>
                <label class="lh-field">
                    <span>OTP code (if 2FA enabled, leave empty otherwise)</span>
                    <InputText @bind-Value="_form.SynologyOtpCode" autocomplete="off" />
                </label>
                <label class="lh-field">
                    <span>Movies destination folder</span>
                    <InputText @bind-Value="_form.SynologyMovieDestination" placeholder="video/movies" />
                </label>
                <label class="lh-field">
                    <span>Series destination folder</span>
                    <InputText @bind-Value="_form.SynologySeriesDestination" placeholder="video/series" />
                </label>

                <div class="lh-row">
                    <button type="button" class="lh-secondary" @onclick="TestSynology" disabled="@_busy">
                        @(_testing ? "Testing…" : "Test connection")
                    </button>
                    @if (_testResult is { } tr)
                    {
                        <span class="@(tr.Ok ? "lh-test-ok" : "lh-test-err")">
                            @(tr.Ok ? "✓ Connected" : "✕ " + tr.Error)
                        </span>
                    }
                </div>
            </section>

            <section class="lh-section">
                <h2>Scanning</h2>
                <label class="lh-field">
                    <span>Auto-scan interval (minutes)</span>
                    <InputNumber @bind-Value="_form.ScanIntervalMinutes" min="1" />
                </label>
                <label class="lh-field lh-field-row">
                    <InputCheckbox @bind-Value="_form.ScanOnStartup" />
                    <span>Scan once on app startup</span>
                </label>
            </section>

            <section class="lh-section">
                <h2>Hoster priority</h2>
                <p class="lh-muted">Top hoster wins. Articles whose hosters aren't in this list are skipped at submit time.</p>
                @for (var i = 0; i < _form.HosterPriority.Count; i++)
                {
                    var idx = i;
                    <div class="lh-host-row">
                        <span class="lh-host-rank">@(idx + 1)</span>
                        <InputText @bind-Value="_form.HosterPriority[idx]" />
                        <button type="button" class="lh-link" @onclick="() => MoveHost(idx, -1)" disabled="@(idx == 0)">↑</button>
                        <button type="button" class="lh-link" @onclick="() => MoveHost(idx, 1)" disabled="@(idx == _form.HosterPriority.Count - 1)">↓</button>
                        <button type="button" class="lh-link" @onclick="() => RemoveHost(idx)">remove</button>
                    </div>
                }
                <button type="button" class="lh-secondary" @onclick="AddHost">+ Add hoster</button>
            </section>

            <section class="lh-section">
                <h2>Catalog: TMDB enrichment</h2>
                <p class="lh-muted">
                    Year, genre, rating, runtime and language filters need TMDB metadata.
                    Sign up free at
                    <a href="https://www.themoviedb.org/settings/api" target="_blank" rel="noopener">themoviedb.org/settings/api</a>
                    and paste the API key (v3) below. The background enricher will work
                    through your catalog automatically; you can keep using the app.
                </p>
                <label class="lh-field">
                    <span>TMDB API key (leave blank to keep)</span>
                    <InputText @bind-Value="_form.TmdbApiKey" type="password" autocomplete="off" />
                </label>
                <label class="lh-field lh-field-row">
                    <InputCheckbox @bind-Value="_form.TmdbEnrichmentEnabled" />
                    <span>Enable background enrichment</span>
                </label>
                <label class="lh-field">
                    <span>Parallel workers (1-8)</span>
                    <InputNumber @bind-Value="_form.TmdbEnrichmentConcurrency" min="1" max="8" />
                </label>

                @if (_catalogStats is not null)
                {
                    <div class="lh-row lh-stats">
                        <span><strong>@_catalogStats.Titles.ToString("N0")</strong> titles</span>
                        <span><strong>@_catalogStats.Links.ToString("N0")</strong> links</span>
                        <span><strong>@_catalogStats.Enriched.ToString("N0")</strong> enriched</span>
                        <span><strong>@_catalogStats.EnrichmentFailed.ToString("N0")</strong> failed</span>
                        <span class="lh-muted">enricher: @_catalogStats.EnrichmentRunState</span>
                    </div>
                }
            </section>

            <section class="lh-section">
                <h2>Catalog: import</h2>
                <p class="lh-muted">Upload a Hydracker-style JSON dump (one array of records or one JSON per line, .json or .json.gz).</p>

                <div class="lh-field">
                    <span>Import from public URL (Google Drive supported)</span>
                    <div class="lh-row">
                        <input type="text" @bind="_importUrl" placeholder="https://drive.google.com/file/d/.../view" />
                        <button type="button" class="lh-primary" @onclick="StartImportFromUrl" disabled="@(_ingestion?.State == "running")">
                            Start import
                        </button>
                    </div>
                </div>

                <div class="lh-field">
                    <span>Or upload a local file</span>
                    <InputFile OnChange="OnFilePicked" disabled="@(_ingestion?.State == "running" || _uploading)" />
                </div>

                @if (_uploading)
                {
                    <p class="lh-muted">Uploading… @($"{_uploadedBytes / 1024d / 1024:0.0} MB")</p>
                }
                @if (_ingestion is not null)
                {
                    <div class="lh-row lh-stats">
                        <span>state: <strong>@_ingestion.State</strong></span>
                        <span><strong>@_ingestion.Progress.Read.ToString("N0")</strong> records read</span>
                        <span><strong>@_ingestion.Progress.Titles.ToString("N0")</strong> titles</span>
                        <span><strong>@_ingestion.Progress.Episodes.ToString("N0")</strong> episodes</span>
                        <span><strong>@_ingestion.Progress.Links.ToString("N0")</strong> links</span>
                        @if (_ingestion.Progress.Failed > 0)
                        {
                            <span class="lh-error">@_ingestion.Progress.Failed.ToString("N0") failed</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_ingestion.Error))
                    {
                        <p class="lh-error">@_ingestion.Error</p>
                    }
                    @if (_ingestion.State == "running")
                    {
                        <button class="lh-secondary" type="button" @onclick="CancelImport">Cancel import</button>
                    }
                }
            </section>

            <section class="lh-section">
                <h2>Login (this app)</h2>
                <p class="lh-muted">Used to access this website.</p>
                <label class="lh-field">
                    <span>Username</span>
                    <InputText @bind-Value="_form.AuthUsername" />
                </label>
                <label class="lh-field">
                    <span>Password (leave blank to keep)</span>
                    <InputText @bind-Value="_form.AuthPassword" type="password" autocomplete="new-password" />
                </label>
            </section>

            @if (_message is not null)
            {
                <p class="@(_isError ? "lh-error" : "lh-muted")">@_message</p>
            }

            <div class="lh-card-actions">
                <button class="lh-primary" type="submit" disabled="@_busy">
                    @(_busy ? "Saving…" : "Save")
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _testing;
    private bool _isError;
    private string? _message;
    private SynologyTestResult? _testResult;
    private Settings? _existing;
    private FormModel? _form;

    private CatalogStats? _catalogStats;
    private IngestionStatus? _ingestion;
    private string _importUrl = string.Empty;
    private bool _uploading;
    private long _uploadedBytes;
    private System.Threading.Timer? _poller;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existing = await Api.GetSettingsAsync();
            _form = FormModel.From(_existing);
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _isError = true;
        }
        finally { _loading = false; }
        await RefreshCatalogStatus();
        _poller = new System.Threading.Timer(async _ =>
        {
            try { await InvokeAsync(RefreshCatalogStatus); }
            catch { }
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    public void Dispose() => _poller?.Dispose();

    private async Task RefreshCatalogStatus()
    {
        try
        {
            _catalogStats = await Api.GetCatalogStatsAsync();
            _ingestion = await Api.GetIngestionStatusAsync();
            StateHasChanged();
        }
        catch { /* unauth or transient */ }
    }

    private async Task StartImportFromUrl()
    {
        if (string.IsNullOrWhiteSpace(_importUrl)) return;
        try
        {
            await Api.ImportFromUrlAsync(_importUrl);
            _message = "Import started. Watch progress below.";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = "Failed to start import: " + ex.Message;
            _isError = true;
        }
        await RefreshCatalogStatus();
    }

    private async Task OnFilePicked(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        _uploading = true;
        _uploadedBytes = 0;
        try
        {
            await using var src = file.OpenReadStream(maxAllowedSize: long.MaxValue);
            var counter = new CountingReadStream(src, n => _uploadedBytes += n);
            var resp = await Api.UploadCatalogFileAsync(counter, file.Name);
            if (!resp.IsSuccessStatusCode)
            {
                _message = $"Upload failed: HTTP {(int)resp.StatusCode}";
                _isError = true;
            }
            else
            {
                _message = "Upload received. Ingestion started.";
                _isError = false;
            }
        }
        catch (Exception ex)
        {
            _message = "Upload failed: " + ex.Message;
            _isError = true;
        }
        finally
        {
            _uploading = false;
            await RefreshCatalogStatus();
        }
    }

    private async Task CancelImport()
    {
        await Api.CancelIngestionAsync();
        await RefreshCatalogStatus();
    }

    private sealed class CountingReadStream : Stream
    {
        private readonly Stream _inner;
        private readonly Action<long> _onRead;
        public CountingReadStream(Stream inner, Action<long> onRead) { _inner = inner; _onRead = onRead; }
        public override bool CanRead => _inner.CanRead;
        public override bool CanSeek => false;
        public override bool CanWrite => false;
        public override long Length => _inner.Length;
        public override long Position { get => _inner.Position; set => throw new NotSupportedException(); }
        public override void Flush() { }
        public override int Read(byte[] buffer, int offset, int count)
        { var n = _inner.Read(buffer, offset, count); if (n > 0) _onRead(n); return n; }
        public override async ValueTask<int> ReadAsync(Memory<byte> buffer, CancellationToken ct = default)
        { var n = await _inner.ReadAsync(buffer, ct); if (n > 0) _onRead(n); return n; }
        public override long Seek(long offset, SeekOrigin origin) => throw new NotSupportedException();
        public override void SetLength(long value) => throw new NotSupportedException();
        public override void Write(byte[] buffer, int offset, int count) => throw new NotSupportedException();
    }

    private async Task Save()
    {
        if (_form is null) return;
        _busy = true;
        _message = null;
        try
        {
            await Api.SaveSettingsAsync(_form.ToUpdate());
            _existing = await Api.GetSettingsAsync();
            _form = FormModel.From(_existing);
            _message = "Saved.";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = "Failed: " + ex.Message;
            _isError = true;
        }
        finally { _busy = false; }
    }

    private async Task TestSynology()
    {
        _testing = true;
        _testResult = null;
        try { _testResult = await Api.TestSynologyAsync(); }
        catch (Exception ex) { _testResult = new SynologyTestResult(false, ex.Message); }
        finally { _testing = false; }
    }

    private void AddHost() => _form!.HosterPriority.Add("");
    private void RemoveHost(int i) => _form!.HosterPriority.RemoveAt(i);
    private void MoveHost(int i, int delta)
    {
        var list = _form!.HosterPriority;
        var j = i + delta;
        if (j < 0 || j >= list.Count) return;
        (list[i], list[j]) = (list[j], list[i]);
    }

    private sealed class FormModel
    {
        public string SynologyBaseUrl { get; set; } = "";
        public string SynologyUsername { get; set; } = "";
        public string SynologyPassword { get; set; } = "";
        public string? SynologyOtpCode { get; set; }
        public string SynologyMovieDestination { get; set; } = "";
        public string SynologySeriesDestination { get; set; } = "";
        public int ScanIntervalMinutes { get; set; }
        public bool ScanOnStartup { get; set; }
        public List<string> HosterPriority { get; set; } = new();
        public string AuthUsername { get; set; } = "";
        public string AuthPassword { get; set; } = "";
        public string TmdbApiKey { get; set; } = "";
        public bool TmdbEnrichmentEnabled { get; set; } = true;
        public int TmdbEnrichmentConcurrency { get; set; } = 4;

        public static FormModel From(Settings s) => new()
        {
            SynologyBaseUrl = s.SynologyBaseUrl,
            SynologyUsername = s.SynologyUsername,
            SynologyPassword = "",
            SynologyOtpCode = s.SynologyOtpCode,
            SynologyMovieDestination = s.SynologyMovieDestination,
            SynologySeriesDestination = s.SynologySeriesDestination,
            ScanIntervalMinutes = s.ScanIntervalMinutes,
            ScanOnStartup = s.ScanOnStartup,
            HosterPriority = s.HosterPriority.ToList(),
            AuthUsername = s.AuthUsername,
            AuthPassword = "",
            TmdbApiKey = "",
            TmdbEnrichmentEnabled = s.TmdbEnrichmentEnabled,
            TmdbEnrichmentConcurrency = s.TmdbEnrichmentConcurrency
        };

        public UpdateSettings ToUpdate() => new(
            SynologyBaseUrl: SynologyBaseUrl,
            SynologyUsername: SynologyUsername,
            SynologyPassword: SynologyPassword,
            SynologyOtpCode: SynologyOtpCode,
            SynologyMovieDestination: SynologyMovieDestination,
            SynologySeriesDestination: SynologySeriesDestination,
            ScanIntervalMinutes: ScanIntervalMinutes,
            ScanOnStartup: ScanOnStartup,
            HosterPriority: HosterPriority.Where(h => !string.IsNullOrWhiteSpace(h)).ToList(),
            AuthUsername: AuthUsername,
            AuthPassword: AuthPassword,
            TmdbApiKey: TmdbApiKey,
            TmdbEnrichmentEnabled: TmdbEnrichmentEnabled,
            TmdbEnrichmentConcurrency: TmdbEnrichmentConcurrency);
    }
}
