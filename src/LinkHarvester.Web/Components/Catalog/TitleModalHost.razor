@*
    Self-contained host for the title-detail modal: opens by id, loads the
    title + inventory in parallel, pre-selects the best link per missing
    episode, refines selection once inventory lands, and sends.

    Used by both /catalog and / (inbox) so the open/load/send pipeline
    exists once.

    Public surface:
      - OpenAsync(int titleId)            — call from parent on tile click.
      - Close()                           — explicit close.
      - PrefetchInventoryAsync(int id)    — warm the cache during multi-select.
      - InventoryCache (read-only)        — for callers that want owned-set on send.
      - TitleCache     (read-only)        — same.
*@

@inject HarvesterApi Api

@if (_selectedTitle is not null)
{
    <TitleDetailModal
        Title="_selectedTitle"
        SelectedLinkIds="_selectedLinkIds"
        Sending="_sending"
        SendOk="_sendOk"
        SendMessage="_sendMessage"
        Inventory="_inventory"
        InventoryLoading="_inventoryLoading"
        OwnedEpisodes="_ownedEpisodes"
        OnClose="Close"
        OnToggleLink="@(args => ToggleLink(args.LinkId, args.On))"
        OnSend="SendSelected" />
}

@code {
    [Parameter] public EventCallback OnSendComplete { get; set; }

    private TitleDetail? _selectedTitle;
    private HashSet<int> _selectedLinkIds = new();
    private bool _sending;
    private bool _sendOk;
    private string? _sendMessage;
    private InventoryResult? _inventory;
    private bool _inventoryLoading;
    private HashSet<(int s, int e)> _ownedEpisodes = new();

    // Shared caches across modal opens + multi-select prefetch. Limited to
    // session scope — discarded on page navigation. Keyed by CatalogTitleId.
    private readonly Dictionary<int, Task<TitleDetail?>> _titleCache = new();
    private readonly Dictionary<int, Task<InventoryResult?>> _inventoryCache = new();

    public IReadOnlyDictionary<int, Task<TitleDetail?>> TitleCache => _titleCache;
    public IReadOnlyDictionary<int, Task<InventoryResult?>> InventoryCache => _inventoryCache;

    public async Task OpenAsync(int id)
    {
        try
        {
            // Fire both fetches up front; render as soon as title lands.
            var titleTask = GetOrFetchTitle(id);
            var inventoryTask = GetOrFetchInventory(id);

            var title = await titleTask;
            if (title is null) return;
            _selectedTitle = title;
            _selectedLinkIds = new HashSet<int>();
            _sendMessage = null;
            _inventory = null;
            _ownedEpisodes = new();
            ApplyInitialSelection(title);
            StateHasChanged();

            _inventoryLoading = true;
            StateHasChanged();
            try
            {
                var result = await inventoryTask;
                _inventory = result;
                if (result is { Ok: true, Exists: true })
                    RefineSelectionWithOwned(title, result);
            }
            catch (Exception ex)
            {
                _inventory = new InventoryResult(
                    Ok: false, Error: ex.Message, Exists: false,
                    FolderPath: string.Empty, SeasonNumber: null, Files: new());
            }
            finally
            {
                _inventoryLoading = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _sendOk = false;
            _sendMessage = "Could not open title: " + ex.Message;
            StateHasChanged();
        }
    }

    public void Close()
    {
        _selectedTitle = null;
        _inventory = null;
        _inventoryLoading = false;
        _ownedEpisodes = new();
        StateHasChanged();
    }

    public Task PrefetchInventoryAsync(int id)
    {
        _ = GetOrFetchTitle(id);
        _ = GetOrFetchInventory(id);
        return Task.CompletedTask;
    }

    public void ClearInventoryCache() => _inventoryCache.Clear();

    private Task<TitleDetail?> GetOrFetchTitle(int id)
    {
        if (!_titleCache.TryGetValue(id, out var task))
        {
            task = Api.GetTitleAsync(id);
            _titleCache[id] = task;
        }
        return task;
    }

    private Task<InventoryResult?> GetOrFetchInventory(int id)
    {
        if (!_inventoryCache.TryGetValue(id, out var task))
        {
            task = Api.GetTitleInventoryAsync(id);
            _inventoryCache[id] = task;
        }
        return task;
    }

    private void ToggleLink(int id, bool on)
    {
        if (on) _selectedLinkIds.Add(id); else _selectedLinkIds.Remove(id);
    }

    private async Task SendSelected()
    {
        if (_selectedLinkIds.Count == 0) return;
        _sending = true;
        _sendMessage = null;
        StateHasChanged();
        try
        {
            var res = await Api.SendCatalogLinksAsync(_selectedLinkIds);
            _sendOk = res.Ok;
            _sendMessage = res.Ok
                ? $"Sent {res.Submitted} link(s) to DSM ({res.TaskIds.Count} task(s) created)."
                : (res.Error ?? "Send failed.");
            if (res.Ok)
            {
                // What's on disk just changed; drop the inventory cache so the
                // next open re-checks. Title cache stays — title metadata
                // hasn't changed.
                _inventoryCache.Clear();
                await OnSendComplete.InvokeAsync();
            }
        }
        catch (Exception ex) { _sendOk = false; _sendMessage = ex.Message; }
        finally { _sending = false; StateHasChanged(); }
    }

    private void ApplyInitialSelection(TitleDetail title)
    {
        _selectedLinkIds.Clear();
        var episodes = title.Episodes ?? new();
        if (episodes.Count > 0)
        {
            foreach (var ep in episodes)
            {
                var bestForEp = (ep.Links ?? new())
                    .OrderBy(l => HostRank(l.Host))
                    .ThenByDescending(l => l.SizeBytes ?? 0)
                    .FirstOrDefault();
                if (bestForEp is not null) _selectedLinkIds.Add(bestForEp.Id);
            }
        }
        else
        {
            var bestTitle = (title.Links ?? new())
                .OrderBy(l => HostRank(l.Host))
                .ThenByDescending(l => l.SizeBytes ?? 0)
                .FirstOrDefault();
            if (bestTitle is not null) _selectedLinkIds.Add(bestTitle.Id);
        }
    }

    private void RefineSelectionWithOwned(TitleDetail title, InventoryResult inv)
    {
        var owned = ParseOwnedEpisodes(inv);
        _ownedEpisodes = owned;
        if (owned.Count == 0) return;
        foreach (var ep in title.Episodes ?? new())
        {
            var isOwned = ep.IsFullSeason
                ? owned.Any(o => o.s == ep.SeasonNumber)
                : owned.Contains((ep.SeasonNumber, ep.EpisodeNumber));
            if (!isOwned) continue;
            foreach (var l in ep.Links ?? new())
                _selectedLinkIds.Remove(l.Id);
        }
    }

    private static readonly System.Text.RegularExpressions.Regex EpisodeRx =
        new(@"(?:S(\d{1,2})E(\d{1,2})|\b(\d{1,2})x(\d{1,2})\b)",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase
            | System.Text.RegularExpressions.RegexOptions.Compiled);

    public static HashSet<(int s, int e)> ParseOwnedEpisodes(InventoryResult? inv)
    {
        var set = new HashSet<(int, int)>();
        if (inv is null || !inv.Exists) return set;
        foreach (var f in inv.Files)
        {
            var m = EpisodeRx.Match(f.Name);
            if (!m.Success) continue;
            var sg = m.Groups[1].Success ? m.Groups[1] : m.Groups[3];
            var eg = m.Groups[2].Success ? m.Groups[2] : m.Groups[4];
            if (int.TryParse(sg.Value, out var s) && int.TryParse(eg.Value, out var e))
                set.Add((s, e));
        }
        return set;
    }

    // Hoster pre-select ordering. Hardcoded for now; the audit flagged that
    // this should read user-configured HosterPriority instead, but plumbing
    // settings through is a separate change.
    public static int HostRank(string? host)
    {
        if (string.IsNullOrWhiteSpace(host)) return 9;
        var h = host.ToLowerInvariant();
        if (h.Contains("1fichier")) return 0;
        if (h.Contains("rapidgator")) return 1;
        if (h.Contains("uploady")) return 2;
        if (h.Contains("nitroflare")) return 3;
        return 9;
    }
}
